# Go Backend Environment Configuration
PORT=8080
ENV=development
APP_NAME=nets-logistics-backend

# Server & CORS
SERVER_HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://localhost:4173

# Database Configuration (PostgreSQL / SQLite)
DB_DRIVER=sqlite
DB_SOURCE=./storage/database.db
